# LI.FI WDK Swidge Protocol — example environment configuration
# Copy this file to .env and fill in your values. Never commit .env to version control.

# BIP-39 seed phrase for the wallet account used in examples (12 or 24 words)
SEED_PHRASE=your twelve word seed phrase goes here and is never shared

# JSON-RPC URL for the source chain (Ethereum mainnet)
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# LI.FI integrator identifier (optional — register at https://li.fi)
LIFI_INTEGRATOR=your-integrator-id

# LI.FI API key for higher rate limits (optional — never expose client-side)
LIFI_API_KEY=
